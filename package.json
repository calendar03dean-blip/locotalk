{
  "name": "spota-fresh",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "server": "node server/index.js",
    "server:dev": "cd server && npx nodemon index.js",
    "tokens:export": "node scripts/theme-to-tokens.js",
    "tokens:build": "style-dictionary build --config sd.config.js",
    "tokens:sync": "npm run tokens:export && echo '→ Figma Token Studio에서 tokens/tokens.json을 import 하세요'",
    "eas:login": "npx eas login",
    "eas:init": "npx eas init",
    "build:dev": "npx eas build --platform ios --profile development",
    "build:preview": "npx eas build --platform ios --profile preview",
    "build:ios": "npx eas build --platform ios --profile production",
    "build:android": "npx eas build --platform android --profile production",
    "submit:ios": "npx eas submit --platform ios"
  },
  "dependencies": {
    "@expo/cli": "^56.1.13",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-kakao/core": "^2.4.5",
    "@react-native-kakao/user": "^2.4.5",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.9.26",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-iap": "^15.3.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eas-cli": "^20.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
